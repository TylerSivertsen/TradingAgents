# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Alpaca paper trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_DAYTRADER_SYMBOLS=SPY,QQQ
ALPACA_DAYTRADER_MAX_NOTIONAL=1000
ALPACA_DAYTRADER_MAX_EXPOSURE_PCT=0.20
ALPACA_DAYTRADER_MIN_CASH_RESERVE_PCT=0.05

# ORIA-inspired quant pipeline
ALLOW_LIVE_TRADING=false
TRADING_DRY_RUN=true
QUANT_ENABLED=true
QUANT_SYMBOLS=AAPL,MSFT,NVDA,SPY
QUANT_MAX_GROSS_EXPOSURE=1.0
QUANT_MAX_NET_EXPOSURE=0.5
QUANT_MAX_POSITION_WEIGHT=0.15
QUANT_MAX_SLEEVE_WEIGHT=0.35
QUANT_MIN_CASH_WEIGHT=0.10
QUANT_TARGET_VOLATILITY=0.15
QUANT_MAX_DAILY_LOSS_PCT=0.02
QUANT_MAX_TURNOVER_PER_DAY=0.50
QUANT_COVARIANCE_LOOKBACK_BARS=120
QUANT_RETURN_LOOKBACK_BARS=60
QUANT_MAX_PARTICIPATION_RATE=0.05
QUANT_MAX_SPREAD_BPS=20
QUANT_PREFER_LIMIT_ORDERS=true
QUANT_ALLOW_MARKET_ORDERS=false

# Dynamic market universe discovery
UNIVERSE_ENABLED=true
UNIVERSE_SOURCE=alpaca
UNIVERSE_MAX_SCAN_SYMBOLS=3000
UNIVERSE_MAX_FOCUS_SYMBOLS=25
UNIVERSE_CACHE_DIR=data/universe
UNIVERSE_SEED_SYMBOLS=
UNIVERSE_EXCLUDED_SYMBOLS=
UNIVERSE_MIN_PRICE=2.0
UNIVERSE_MAX_PRICE=1000.0
UNIVERSE_MIN_AVG_DAILY_VOLUME=1000000
UNIVERSE_MIN_INTRADAY_VOLUME=100000
UNIVERSE_MAX_SPREAD_BPS=30
UNIVERSE_MIN_ATR_PCT=0.005
UNIVERSE_MAX_ATR_PCT=0.12
